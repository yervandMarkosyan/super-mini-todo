<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="todo_list_in_C" />
		<Option pch_mode="2" />
		<Option compiler="gcc" />
		<Build>
			<Target title="Debug">
				<Option output="bin/Debug/todo_list_in_C" prefix_auto="1" extension_auto="1" />
